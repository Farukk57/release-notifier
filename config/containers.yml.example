# release-notifier container configuration
# Copy this file to containers.yml and edit to match your stack.

settings:
  # How often to check for new releases (hours)
  check_interval_hours: 6

  # Only notify for stable releases (no pre-releases, nightlies, RCs)
  # Can be overridden per container with stable_only: false
  stable_only: true

  # ntfy topic URL -- can also be set via NTFY_URL environment variable
  # ntfy_url: "https://ntfy.sh/your-unique-topic"

  # Notification provider: ntfy (default), homeassistant, or both
  # Can also be set via NOTIFY_PROVIDER environment variable
  # notify_provider: ntfy

  # Home Assistant settings (only needed if notify_provider is homeassistant or both)
  # hass_url: http://homeassistant.local:8123    # or HASS_URL env var
  # hass_token: your_long_lived_token             # or HASS_TOKEN env var
  # hass_notify_service: mobile_app_your_phone    # or HASS_NOTIFY_SERVICE env var

  # AI provider: claude (default) or ollama
  # Can also be set via AI_PROVIDER environment variable
  # ai_provider: claude

  # Ollama settings (only needed if ai_provider is ollama)
  # ollama_url: http://ollama:11434    # or OLLAMA_URL env var
  # ollama_model: llama3.2             # or OLLAMA_MODEL env var

containers:
  # Minimal example:
  - name: Immich
    github: immich-app/immich
    image: ghcr.io/immich-app/immich-server

  # Full example with all options:
  # - name: Sonarr
  #   github: Sonarr/Sonarr
  #   image: lscr.io/linuxserver/sonarr   # registry image for digest tracking
  #   container: sonarr                    # actual Docker container name if different from 'name'
  #   stable_only: false                   # include pre-releases (needed for *arr apps)
