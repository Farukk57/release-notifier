# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── AI Provider ────────────────────────────────────────────────────────────────
# Options: claude (default), openai, ollama
# AI_PROVIDER=claude

# Claude — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini   # or gpt-4o for higher quality

# Ollama (free, local) — requires Ollama running on your network
# OLLAMA_URL=http://192.168.1.10:11434
# OLLAMA_MODEL=mistral

# ── Notifications ──────────────────────────────────────────────────────────────
# Options: ntfy (default), homeassistant, both
# NOTIFY_PROVIDER=ntfy

# ntfy — required if NOTIFY_PROVIDER is ntfy or both
# Get a free topic at https://ntfy.sh or use your self-hosted instance
NTFY_URL=https://ntfy.sh/your-unique-topic
# NTFY_TOKEN=   # optional: only needed for private ntfy topics

# Home Assistant — required if NOTIFY_PROVIDER is homeassistant or both
# Create a long-lived token at your HA profile → Security → Long-lived access tokens
# Find your notify service at Developer tools → Actions → search notify.mobile_app
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=your_long_lived_access_token
# HASS_NOTIFY_SERVICE=mobile_app_your_phone

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Recommended — avoids the 60 req/h unauthenticated rate limit
# Create one at https://github.com/settings/tokens (no scopes needed)
# GITHUB_TOKEN=

# ── Security ───────────────────────────────────────────────────────────────────
# Recommended if exposing via Traefik or reverse proxy
# Protects POST /api/check from unauthenticated triggers
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# API_KEY=
