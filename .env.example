# Copy to .env and fill in your values

# Required: get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Required: ntfy topic URL
# Use https://ntfy.sh/pick-a-unique-topic-name   (free, no account needed)
NTFY_URL=https://ntfy.sh/your-unique-topic

# Optional: ntfy access token (if your topic is private)
NTFY_TOKEN=

# Optional: GitHub PAT to avoid the 60 req/h unauthenticated rate limit
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Optional but recommended if exposing via Traefik:
# Set a random secret to protect POST /api/check from unauthenticated triggers.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Optional: use Ollama instead of Claude for free local AI summaries
# AI_PROVIDER=ollama
# OLLAMA_URL=http://192.168.1.10:11434
# OLLAMA_MODEL=mistral

# Optional: Home Assistant integration
# NOTIFY_PROVIDER=both
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=your_long_lived_access_token
# HASS_NOTIFY_SERVICE=mobile_app_your_phone
